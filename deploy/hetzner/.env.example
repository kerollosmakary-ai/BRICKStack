# ── BRICKStack Hetzner Environment ───────────────────────────────
# Copy to .env and edit

# LLM Provider (see llm_client.py for aliases)
LLM_MODEL=deepseek

# API Keys (set only the one for your provider)
DEEPSEEK_API_KEY=sk-your-deepseek-key
# OPENAI_API_KEY=sk-your-openai-key
# QWEN_API_KEY=sk-your-qwen-key
# GROQ_API_KEY=gsk-your-groq-key
# ANTHROPIC_API_KEY=sk-ant-your-key

# Optional: Fallback model if primary fails
FALLBACK_MODEL=local

# Server
API_HOST=127.0.0.1
API_PORT=8000
WORKERS=1

# Local Ollama (if using local mode)
OLLAMA_BASE_URL=http://localhost:11434
