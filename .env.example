# BRICKStack Studio — Environment Variables
# Copy to .env and fill in values

# API
API_HOST=0.0.0.0
API_PORT=8000

# LLM Provider (OpenAI-compatible: DeepSeek, OpenAI, etc.)
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/brickstack

# Redis (session state + rate limiting)
REDIS_URL=redis://localhost:6379/0

# Sandbox (Docker)
SANDBOX_IMAGE=brickstack-sandbox
SANDBOX_TIMEOUT=120
SANDBOX_MEMORY=512m
SANDBOX_CPU=1.0

# Auth
JWT_SECRET=change-this-to-a-random-secret
